<%- include('partials/header', { title: 'Signature Saved', heading: 'Signature saved', subheading: 'Your name is now on the DHA.' }) %>

<div class="card" style="text-align:center;">
  <div style="font-size:28px;font-weight:800;margin-bottom:8px;">Thanks, <%= signerName %>.</div>
  <div class="muted" style="margin-bottom:10px;">Your signature has been attached to <strong><%= dha.projectName || 'today’s DHA' %></strong>.</div>
  <div class="count-pill" style="margin-bottom:16px;"><%= progress.progressText %></div>
  <div class="actions" style="justify-content:center;">
    <a class="btn primary" href="/sign/<%= dha.signToken %>">Add another signer</a>
    <a class="btn secondary" href="/dhas/<%= dha.id %>">View completed sheet</a>
  </div>
</div>

<%- include('partials/footer') %>
