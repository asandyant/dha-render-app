<%- include('partials/header', { title: 'Crew Sign', heading: 'Worker signature page', subheading: (dha.projectName || 'DHA') + ' · ' + (dha.date || '') }) %>

<div class="card no-print">
  <div class="topbar">
    <div>
      <div style="font-size:22px;font-weight:800;">Sign today’s DHA</div>
      <div class="muted">Each worker enters a name, signs, and the completed sheet updates with a live count.</div>
    </div>
    <div class="count-pill"><%= progress.progressText %></div>
  </div>
</div>

<div class="grid two">
  <div class="card">
    <div style="font-size:22px;font-weight:800;margin-bottom:12px;">Before signing</div>
    <p><strong>Project</strong><br><span class="muted"><%= dha.projectName || '—' %></span></p>
    <p><strong>Foreman</strong><br><span class="muted"><%= dha.foreman || '—' %></span></p>
    <p><strong>Task</strong><br><span class="muted"><%= dha.taskDescription || '—' %></span></p>
    <p><strong>Main hazards</strong><br><span class="muted"><%= summaries.hazardText || '—' %></span></p>
    <p><strong>Main controls</strong><br><span class="muted"><%= summaries.controlText || '—' %></span></p>
  </div>

  <div class="card">
    <div style="font-size:22px;font-weight:800;margin-bottom:12px;">Sign this DHA</div>
    <% if (error) { %><div class="alert" style="margin-bottom:12px;"><%= error %></div><% } %>
    <form method="POST" action="/sign/<%= dha.signToken %>">
      <div class="grid two">
        <div>
          <label class="field-label">Your name</label>
          <input type="text" name="signerName" required>
        </div>
        <div>
          <label class="field-label">Role</label>
          <select name="role">
            <option value="Crew Member">Crew Member</option>
            <option value="Operator">Operator</option>
            <option value="Laborer">Laborer</option>
            <option value="Foreman">Foreman</option>
            <option value="Superintendent">Superintendent</option>
          </select>
        </div>
      </div>
      <div style="margin-top:14px;">
        <label class="field-label">Signature</label>
        <canvas id="signature-pad" class="signature-pad"></canvas>
        <input type="hidden" id="signatureData" name="signatureData">
        <div class="actions" style="margin-top:12px;">
          <button class="btn secondary" type="button" id="clear-signature">Clear signature</button>
          <button class="btn primary" type="submit">Submit signature</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@5.1.0/dist/signature_pad.umd.min.js"></script>
<script src="/js/signature.js"></script>

<%- include('partials/footer') %>
