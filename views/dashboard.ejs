<%- include('partials/header', { title: "DHA Dashboard", heading: "RK19-A", subheading: "Office view for recent DHAs.", showDashboard: false, showStart: true }) %>

<div class="card no-print hero-card">
  <div style="display:flex;justify-content:space-between;gap:16px;align-items:center;flex-wrap:wrap;">
    <div>
      <div style="font-size:28px;font-weight:800;">Recent DHAs</div>
      <div class="muted" style="margin-top:6px;max-width:760px;">Shane does not need this page in the field. This is mainly here for office review and re-opening saved DHAs.</div>
      <div class="small muted" style="margin-top:8px;">Date: <strong><%= todayDate %></strong></div>
    </div>
    <div class="actions">
      <a class="btn primary" href="/foreman/start-today">Start Today's DHA</a>
    </div>
  </div>
</div>

<div class="card no-print">
  <% if (!dhas.length) { %>
    <div class="muted">No DHAs created yet.</div>
  <% } else { %>
    <div class="signed-list">
      <% dhas.forEach(function(dha) { %>
        <div class="signed-item" style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;">
          <div>
            <div><strong><%= dha.projectName || 'DHA' %></strong> · <span class="muted"><%= dha.date || '' %></span></div>
            <div class="small muted"><%= dha.foreman || '' %> · <%= dha.taskDescription || '' %></div>
          </div>
          <div class="actions">
            <a class="btn secondary" href="/dhas/<%= dha.id %>">Open</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
