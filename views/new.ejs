<%- include('partials/header', { title: 'New DHA', heading: 'Editable DHA template', subheading: 'Your Safespan defaults are prefilled. Use Start Today for the fastest field flow.', showDashboard: false, showStart: true }) %>

<div class="card no-print">
  <div class="topbar">
    <div>
      <div style="font-size:22px;font-weight:800;">Safespan default template</div>
      <div class="muted">This page is for tweaking the defaults before saving a DHA manually. Most days Shane can skip this and tap <strong>Start Today's DHA</strong>.</div>
    </div>
    <a class="btn primary" href="/foreman/start-today">Start Today's DHA</a>
  </div>
</div>

<form method="POST" action="/foreman/new">
  <div class="paper">
    <div class="pdf-header">
      <div class="ab-logo"><span>AB</span> <span>American<br>Bridge</span></div>
      <div class="pdf-title">DAILY HAZARD ANALYSIS</div>
      <div class="jagd-box">JAGD</div>
    </div>

    <table class="pdf-table">
      <tr>
        <td colspan="2"><div class="cell-line"><div class="cell-label">Project Name / #:</div><div class="cell-value"><input type="text" name="projectName" value="<%= defaults.projectName %>"></div></div></td>
        <td><div class="cell-line"><div class="cell-label">Date:</div><div class="cell-value"><input type="date" name="date" value="<%= defaults.date %>"></div></div></td>
        <td><div class="cell-line"><div class="cell-label">Time:</div><div class="cell-value"><input type="time" name="time" value="<%= defaults.time %>"></div></div></td>
      </tr>
      <tr>
        <td colspan="2"><div class="cell-line"><div class="cell-label">Superintendent:</div><div class="cell-value"><input type="text" name="superintendent" value="<%= defaults.superintendent %>"></div></div></td>
        <td><div class="cell-line"><div class="cell-label">Foreman:</div><div class="cell-value"><input type="text" name="foreman" value="<%= defaults.foreman %>"></div></div></td>
        <td><div class="cell-line"><div class="cell-label">Weather:</div><div class="cell-value"><input type="text" name="weather" value="<%= defaults.weather %>"></div></div></td>
      </tr>
      <tr>
        <td colspan="2"><div class="cell-line"><div class="cell-label">Work Area Location(s):</div><div class="cell-value"><input type="text" name="workAreaLocation" value="<%= defaults.workAreaLocation %>"></div></div></td>
        <td colspan="2"><div class="cell-line"><div class="cell-label">Expected Crew Signers:</div><div class="cell-value"><input type="text" name="expectedCrewCount" value="<%= defaults.expectedCrewCount || defaultCrewCount %>"></div></div></td>
      </tr>
      <tr>
        <td colspan="2"><div class="cell-label" style="border-right:0;">Work Area Surveyed:</div><div class="full-line"><label class="radio-inline"><input type="radio" name="workAreaSurveyed" value="Yes" <%= defaults.workAreaSurveyed === 'Yes' ? 'checked' : '' %>> Yes</label><label class="radio-inline"><input type="radio" name="workAreaSurveyed" value="N/A" <%= defaults.workAreaSurveyed === 'N/A' ? 'checked' : '' %>> N/A</label></div></td>
        <td colspan="2"><div class="cell-label" style="border-right:0;">Associated JHA Reviewed / Signed by Crew:</div><div class="full-line"><label class="radio-inline"><input type="radio" name="jhaReviewed" value="Yes" <%= defaults.jhaReviewed === 'Yes' ? 'checked' : '' %>> Yes</label><label class="radio-inline"><input type="radio" name="jhaReviewed" value="N/A" <%= defaults.jhaReviewed === 'N/A' ? 'checked' : '' %>> N/A</label></div></td>
      </tr>
      <tr>
        <td colspan="4"><div class="cell-label" style="border-right:0;">Task Description:</div><div class="full-line"><textarea name="taskDescription"><%= defaults.taskDescription %></textarea></div></td>
      </tr>
      <tr>
        <td colspan="2"><div class="cell-label" style="border-right:0;">Are Others Working Above, Below or Beside Your Work Areas?</div><div class="full-line"><label class="radio-inline"><input type="radio" name="othersWorking" value="Yes" <%= defaults.othersWorking === 'Yes' ? 'checked' : '' %>> Yes</label><label class="radio-inline"><input type="radio" name="othersWorking" value="N/A" <%= defaults.othersWorking === 'N/A' ? 'checked' : '' %>> N/A</label></div></td>
        <td colspan="2"><div class="cell-label" style="border-right:0;">Have They Been Coordinated / Communicated with?</div><div class="full-line"><label class="radio-inline"><input type="radio" name="coordinatedWithOthers" value="Yes" <%= defaults.coordinatedWithOthers === 'Yes' ? 'checked' : '' %>> Yes</label><label class="radio-inline"><input type="radio" name="coordinatedWithOthers" value="N/A" <%= defaults.coordinatedWithOthers === 'N/A' ? 'checked' : '' %>> N/A</label></div></td>
      </tr>
      <tr>
        <td colspan="4"><div class="cell-label" style="border-right:0;">Were There Any Reported Incidents or Near Misses Yesterday or Today?</div><div class="full-line"><label class="radio-inline"><input type="radio" name="incidentsOrNearMisses" value="Yes" <%= defaults.incidentsOrNearMisses === 'Yes' ? 'checked' : '' %>> Yes</label><label class="radio-inline"><input type="radio" name="incidentsOrNearMisses" value="No" <%= defaults.incidentsOrNearMisses === 'No' ? 'checked' : '' %>> No</label><div style="margin-top:10px;"><label class="field-label">If yes, explain</label><input type="text" name="incidentsExplanation" value="<%= defaults.incidentsExplanation %>"></div></div></td>
      </tr>
      <tr>
        <td colspan="4"><div class="cell-label" style="border-right:0;">Tools, Equipment, Safety Equipment Required to Perform Today’s Task:</div><div class="full-line"><textarea name="toolsEquipment"><%= defaults.toolsEquipment %></textarea></div></td>
      </tr>
      <tr>
        <td colspan="2">
          <div class="section-subbanner">Required Permits/Authorizations/Inspections</div>
          <div class="full-line checks-grid">
            <% permitOptions.forEach(function(item) { %>
              <label class="check-item"><input type="checkbox" name="permits" value="<%= item %>" <%= defaults.permits.includes(item) ? 'checked' : '' %>> <%= item %></label>
            <% }) %>
          </div>
        </td>
        <td colspan="2">
          <div class="section-subbanner">Specific Training Required</div>
          <div class="full-line checks-grid">
            <% trainingOptions.forEach(function(item) { %>
              <label class="check-item"><input type="checkbox" name="training" value="<%= item %>" <%= defaults.training.includes(item) ? 'checked' : '' %>> <%= item %></label>
            <% }) %>
          </div>
        </td>
      </tr>
    </table>

    <div class="section-banner">Work Activities</div>
    <table class="pdf-table">
      <thead class="work-head">
        <tr>
          <th class="yellow">TASK STEPS</th>
          <th class="red">HAZARDS Associated w/ The Task</th>
          <th class="green">CONTROLS Associated w/ The Task</th>
        </tr>
      </thead>
      <tbody>
        <% defaults.taskRows.forEach(function(row) { %>
          <tr class="work-row">
            <td><textarea name="taskStep"><%= row.taskStep %></textarea></td>
            <td><textarea name="hazard"><%= row.hazard %></textarea></td>
            <td><textarea name="control"><%= row.control %></textarea></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="print-actions no-print" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end;">
      <a class="btn secondary" href="/foreman/start-today">Use default Start Today flow</a>
      <button class="btn primary" type="submit">Save DHA</button>
    </div>
  </div>
</form>

<%- include('partials/footer') %>
